{
  "name": "iptv-player",
  "version": "1.0.5-alpha",
  "description": "Десктопний IPTV плеєр на базі Tauri + React + TypeScript",
  "author": "IPTV Player",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
