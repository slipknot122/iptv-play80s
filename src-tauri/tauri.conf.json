{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "iptv-player",
  "version": "0.1.0",
  "identifier": "com.iptv.player",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite-dev",
    "beforeBuildCommand": "npm run vite-build"
  },
  "app": {
    "windows": [
      {
        "title": "IPTV Player",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
